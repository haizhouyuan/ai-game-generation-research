#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"

section() {
  printf '\n## %s\n' "$1"
}

run_with_timeout() {
  local seconds="$1"
  shift
  perl -e 'alarm shift @ARGV; exec @ARGV' "${seconds}" "$@"
}

section "Versions"
printf 'claude=%s\n' "$(command -v claude || true)"
claude --version 2>/dev/null || true
printf 'gemini=%s\n' "$(command -v gemini || true)"
gemini --version 2>/dev/null || true

section "Credentials Presence"
"${ROOT_DIR}/bin/runner-env-check" \
  | sed -E \
      -e 's#^(credentials)=.*#\1=<private>#' \
      -e 's#^(kimi_config)=.*#\1=<private>#'

section "Claude MiniMax MCP"
run_with_timeout 25 env RUNNER_READ_ONLY=1 "${ROOT_DIR}/bin/claudeminmax" mcp list 2>&1 \
  || printf 'mcp-list=failed-or-timed-out\n'

section "Claude Kimi MCP"
run_with_timeout 25 env RUNNER_READ_ONLY=1 "${ROOT_DIR}/bin/claudekimi" mcp list 2>&1 \
  || printf 'mcp-list=failed-or-timed-out\n'

section "Gemini MCP"
run_with_timeout 25 gemini mcp list 2>&1 || printf 'mcp-list=failed-or-timed-out\n'

section "Gemini Skills"
gemini skills list 2>&1 || true

section "Runner Commands"
for command in \
  claudeminmax \
  claudekimi \
  runner-env-check \
  runner-review \
  runner-worker \
  runner-capabilities-audit
do
  path="${ROOT_DIR}/bin/${command}"
  if [ -x "${path}" ]; then
    printf '%s=executable\n' "${command}"
  else
    printf '%s=missing-or-not-executable\n' "${command}"
  fi
done

section "Runner Prompt Templates"
find "${ROOT_DIR}/prompts" -maxdepth 1 -type f -name '*.md' -print | sort
