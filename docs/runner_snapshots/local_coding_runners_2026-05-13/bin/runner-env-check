#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
SECRETS_ENV="${RUNNER_SECRETS_ENV:-${ROOT_DIR}/.secrets/credentials.env}"

if [ -f "${SECRETS_ENV}" ]; then
  set -a
  # shellcheck disable=SC1090
  . "${SECRETS_ENV}"
  set +a
fi

check_var() {
  local name="$1"
  if [ -n "${!name:-}" ]; then
    printf '%s=present\n' "${name}"
  else
    printf '%s=missing\n' "${name}"
  fi
}

printf 'claude=%s\n' "$(command -v claude || true)"
claude --version
check_var MINIMAX_API_KEY
check_var KIMI_CODINGPLAN_API_KEY
printf 'kimi_config=%s\n' "${ROOT_DIR}/.kimi/config.toml"
printf 'credentials=%s\n' "${SECRETS_ENV}"
